# Required in production
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret

# Comma-separated admin account emails after they sign up
ADMIN_EMAILS=owner@example.com

# Optional: only add after your payment processor approves the exact business/product line
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Crypto payment addresses shown at checkout
BTC_PAYMENT_ADDRESS="3QaBoxDHEWnuGy5emvYawoFCM5E5yMEvap"
SOL_PAYMENT_ADDRESS="7NVysM4pSWVq4ZYKnnCwz3fnaA1BgkCex6tARvv7vqBT"
USDC_PAYMENT_ADDRESS="3q2QjuTXc5S8MYo5YdD5ELuBz1ASv5YDcEvmQgw4V6n9"
USDC_PAYMENT_NETWORK="Solana"


# Automatic email confirmations / owner notifications
# Works with any SMTP provider. Fill these in before launch.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ResearchPeps <orders@yourdomain.com>"
ORDER_NOTIFY_EMAIL=your@email.com

CRYPTO_QUOTE_BUFFER=0
CRYPTO_QUOTE_EXPIRES_MINUTES=15

# SHIPPING NOTE: edit data/shipping-rates.json to change country-based shipping charges. United States is set to $15.
